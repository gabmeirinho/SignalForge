SEC_COMPANY_NAME="Your Name or App Name"
SEC_EMAIL="you@example.com"

# Optional LLM configuration.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Docker Compose defaults.
POSTGRES_USER=signalforge
POSTGRES_PASSWORD=signalforge
POSTGRES_DB=signalforge
POSTGRES_PORT=15432
QDRANT_PORT=6333
API_PORT=8000
FRONTEND_PORT=8080
SIGNALFORGE_IMAGE_TAG=phase8

SIGNALFORGE_COLLECTION=sec_chunks
SIGNALFORGE_EMBEDDING_MODEL=jinaai/jina-embeddings-v2-small-en
SIGNALFORGE_PLANNER_MODEL=deepseek-v4-flash
SIGNALFORGE_ANSWER_MODEL=deepseek-v4-flash
SIGNALFORGE_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
SIGNALFORGE_API_BASE_URL=http://localhost:8000

SIGNALFORGE_WORKER_INTERVAL_SECONDS=300
SIGNALFORGE_INGEST_LIMIT_PER_SOURCE=
SIGNALFORGE_ENABLE_SCHEDULED_INGESTION=true
SIGNALFORGE_CHUNK_SIZE=4000
SIGNALFORGE_CHUNK_OVERLAP=500
SIGNALFORGE_VECTORIZE_BATCH_SIZE=16
SIGNALFORGE_LOG_LEVEL=INFO
